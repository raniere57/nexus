<file path="frontend/nginx.conf">
server {
    listen 80;
    server_name localhost;

    # Static assets
    location / {
        root   /usr/share/nginx/html;
        index  index.html;
        try_files $uri $uri/ /index.html;
    }

    # Proxy API requests to backend
    location /api/ {
        resolver 127.0.0.11 valid=30s;
        set $backend_api http://backend:3000;
        proxy_pass $backend_api/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Proxy WebSocket status endpoint
    location /ws/ {
        resolver 127.0.0.11 valid=30s;
        set $backend_ws http://backend:3000;
        proxy_pass $backend_ws/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400; # Keep WS alive
    }
}
</file>

