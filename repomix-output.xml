    </div>
    
    <div class="orbital-map">
      <div 
        v-for="(service, index) in services" 
        :key="service.serviceId"
        class="service-node"
        :class="[`status-${service.overallStatus}`]"
        :style="getNodeStyle(index, services.length)"
      >
        <!-- Connecting Line to Center -->
        <svg class="connection-line">
          <line x1="50%" y1="50%" :x2="getLineX(index, services.length)" :y2="getLineY(index, services.length)" />
          <circle v-if="service.overallStatus === 'online'" class="pulse-dot" r="2" cx="50%" cy="50%">
            <animate attributeName="cx" :values="`50%;${getLineX(index, services.length)}`" dur="3s" repeatCount="indefinite" />
            <animate attributeName="cy" :values="`50%;${getLineY(index, services.length)}`" dur="3s" repeatCount="indefinite" />
            <animate attributeName="opacity" values="0;1;0" dur="3s" repeatCount="indefinite" />
          </circle>
        </svg>

        <div class="node-glow"></div>
        <div class="node-body">
          <div class="node-indicator"></div>
          <div class="node-info">
            <div class="node-env">{{ service.environment }}</div>
            <div class="node-name">{{ service.serviceName }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { computed } from 'vue';
import type { NexusService } from '../types';

const props = defineProps<{
  services: NexusService[]
}>();

// Simple circular layout calculation
const radius = 320; // Distance from center

const getNodeStyle = (index: number, total: number) => {
  if (total === 0) return {};
  const angle = (index / total) * Math.PI * 2 - Math.PI / 2; // Start from top
  const x = Math.cos(angle) * radius;
  const y = Math.sin(angle) * radius;
  
  return {
    transform: `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`
  };
};

const getLineX = (index: number, total: number) => {
  if (total === 0) return '50%';
  const angle = (index / total) * Math.PI * 2 - Math.PI / 2;
  // Center of screen is 0,0 for the node logic, but SVG is absolute to the node
  // The SVG is inside the node, so its 0,0 is top-left of the node.
  // Actually, drawing lines strictly in CSS/HTML is tricky. Let's use a full SVG overlay or simpler hack.
  // Better approach: make connection-line full width/height absolute positioned in the center, and point to the node.
  // Let's modify: the SVG lines should emanate from the node inversely to the center.
  // Center from node perspective is -x, -y.
  const x = -Math.cos(angle) * radius;
  return `calc(50% + ${x}px)`;
};

const getLineY = (index: number, total: number) => {
  if (total === 0) return '50%';
  const angle = (index / total) * Math.PI * 2 - Math.PI / 2;
  const y = -Math.sin(angle) * radius;
  return `calc(50% + ${y}px)`;
};
</script>

